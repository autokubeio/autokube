# Database configuration
# If DATABASE_URL starts with postgres:// or postgresql://, PostgreSQL is used.
# Otherwise, SQLite is used automatically.

# PostgreSQL:
# DATABASE_URL=postgres://user:pass@localhost:5432/autokube

# SQLite (default): stored at DATA_DIR/db/autokube.db
# DATA_DIR=./data

# NODE_TLS_REJECT_UNAUTHORIZED =0
