{
	"name": "autokube",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "bunx --bun vite dev",
		"build": "bunx --bun vite build && bun run post-build",
		"post-build": "bun ./scripts/generate-build-info.ts && bun ./scripts/patch-production-ws.ts",
		"start": "bun ./build/index.js",
		"preview": "bunx --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:generate:sqlite": "drizzle-kit generate --config=drizzle.sqlite.config.ts",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:sqlite": "drizzle-kit migrate --config=drizzle.sqlite.config.ts",
		"db:studio": "drizzle-kit studio",
		"docker:build": "docker build -t autokube:latest .",
		"docker:run": "docker run --rm -p 8080:8080 -v autokube-data:/data autokube:latest",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f autokube",
		"docker:clean": "docker compose down -v && docker volume rm autokube-data 2>/dev/null; bun run docker:run"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/table-core": "^8.21.3",
		"@types/bun": "^1.3.9",
		"@types/js-yaml": "^4.0.9",
		"@types/marked": "^6.0.0",
		"@types/node": "^22",
		"@types/nodemailer": "^7.0.11",
		"@types/qrcode": "^1.5.6",
		"bits-ui": "^2.16.2",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.9",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"formsnap": "^2.0.1",
		"globals": "^17.3.0",
		"layerchart": "2.0.0-next.43",
		"lucide-svelte": "^0.575.0",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.1.1",
		"svelte": "^5.51.0",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.3.6",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.28.1",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@codemirror/lang-javascript": "^6.2.4",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-yaml": "^6.1.2",
		"@codemirror/language": "^6.12.2",
		"@codemirror/state": "^6.5.4",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.39.15",
		"@neodrag/svelte": "^2.3.3",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"clsx": "^2.1.1",
		"codemirror": "^6.0.2",
		"drizzle-orm": "^0.45.1",
		"ldapts": "^8.1.7",
		"marked": "^17.0.4",
		"nodemailer": "^8.0.1",
		"otpauth": "^9.5.0",
		"postgres": "^3.4.8",
		"qrcode": "^1.5.4",
		"svelte-grid": "^5.1.2",
		"tailwind-merge": "^3.5.0"
	}
}